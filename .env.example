DATABASE_URL=postgres://postgres:password@localhost:5432/dev_shg
# Containerized Postgres (docker-compose)
DATABASE_NAME=dev
DATABASE_USER=''
DATABASE_PASSWORD=""
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
JWT_SECRET=secret

# v1 (shg-webapp) source DB for the one-off data migration (yarn migrate:v1).
# Point at a restored pg_dump snapshot of v1, NOT the live production DB.
# Leave unset in normal app runs; only the migration tool reads it.
V1_DATABASE_URL=postgres://postgres:password@localhost:5433/shg_v1


JITSI_JAAS_APP_ID=APPID
JITSI_JAAS_APP_SECRET=secret
JITSI_JAAS_KID=KID
JITSI_JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
provate jitsi key
-----END PRIVATE KEY-----
"

# For NodeMailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="xxx.gmail.com"
SMTP_PASS="app password"
SMTP_FROM="from email"



SENDGRID_FROM_EMAIL="from email"
SENDGRID_API_KEY=API_KEYxxxxxxxx

# SMS gateway (patient-facing). Leave SMS_HOST unset to use the dev LogProvider
# (messages printed to console as [MOCK SMS SENT]). The real gateway is only
# used when NODE_ENV=production AND SMS_HOST is set. When a vendor is chosen,
# edit src/providers/sms-gateway.provider.ts (URL/body/auth) — nothing else.
SMS_HOST=
SMS_API_TOKEN=

# S3 attachments (private bucket; use IAM role or keys in dev)
AWS_REGION=us-east-1
S3_ATTACHMENTS_BUCKET=
# Optional: MinIO / LocalStack
# S3_ENDPOINT=http://localhost:9000
ATTACHMENT_MAX_BYTES=26214400
ATTACHMENT_ALLOWED_CONTENT_TYPES=application/pdf,image/jpeg,image/png,image/webp

# Pusher Channels (realtime notifications + tele-auscultation signaling).
# Leave PUSHER_APP_ID unset to use the dev LogProvider (events printed to console).
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1
PUSHER_USE_TLS=true

# Optional: short-lived JWT TTL for tele-auscultation join links (defaults to JITSI_JOIN_JWT_EXPIRES_IN).
AUSCULTATION_JOIN_JWT_EXPIRES_IN=2h

# Logging: trace | debug | info | warn | error | fatal | silent
# Defaults: production=info, development=debug, test=silent.
LOG_LEVEL=info
